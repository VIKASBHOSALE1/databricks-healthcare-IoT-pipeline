{
  "datasets": [
    {
      "name": "3d3f4306",
      "displayName": "Total Patients",
      "queryLines": [
        "-- Write a query to count distinct patient_ids from patient_vitals_hourly\r\n",
        "-- Expected result: single number\r\n",
        "select count(distinct Patient_ID) from cat_healthcare_iot_patients.gold.gold_patient_vitals_daily \r\n"
      ],
      "catalog": "cat_healthcare_iot_patients",
      "schema": "gold"
    },
    {
      "name": "3a8c84ea",
      "displayName": "Total Critical Alerts Today",
      "queryLines": [
        "-- Write a query to count rows from anomaly_alerts\r\n",
        "-- where alert_severity = 'CRITICAL' :parameter :parameter :parameter \r\n",
        "select count(*) as `Critical alerts` from cat_healthcare_iot_patients.gold.gold_anomaly_alerts where alert_severity = 'CRITICAL' "
      ]
    },
    {
      "name": "c935310e",
      "displayName": "Avg Heart Rate Over Time per Ward",
      "queryLines": [
        "-- Write a query to count rows from anomaly_alerts\r\n",
        "-- where alert_severity = 'CRITICAL'\r\n",
        "select count(*) as `Critical alerts` from cat_healthcare_iot_patients.gold.gold_anomaly_alerts where alert_severity = 'CRITICAL'"
      ]
    },
    {
      "name": "8ba57cf0",
      "displayName": "Alert Count by date",
      "queryLines": [
        "SELECT \r\n",
        "  Patient_ID As PatientID, \r\n",
        "  Heart_Rate_bpm as `Heart Rate`, \r\n",
        "  blood_pressure_status as `Blood Pressure`, \r\n",
        "  alert_severity as `Alert Severity`\r\n",
        "  FROM cat_healthcare_iot_patients.gold.gold_anomaly_alerts\r\n",
        "WHERE alert_severity = 'CRITICAL'\r\n",
        "ORDER BY Silver_Processed_At DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "a5e40c03",
      "displayName": "Most Recent Critical Alerts",
      "queryLines": [
        "-- Write a query to show the last 20 critical alerts\r\n",
        "-- from anomaly_alerts\r\n",
        "-- where alert_severity = 'CRITICAL'\r\n",
        "-- order by alert_time descending\r\n",
        "-- select: patient_id, ward_id, alert_time, heart_rate, spo2, temperature, alert_category\r\n",
        "--Table\r\n",
        "select Patient_ID, date, Heart_Rate_bpm, Temperature_C, alert_severity, is_anomaly from cat_healthcare_iot_patients.gold.gold_anomaly_alerts \r\n",
        "where alert_severity = 'CRITICAL' order by Silver_Processed_At desc limit 20"
      ]
    },
    {
      "name": "b99e1ce3",
      "displayName": "Performance by Shift",
      "queryLines": [
        "-- Write a query from ward_summary\r\n",
        "-- select: ward_id, shift, alert_count, avg_heart_rate\r\n",
        "-- This will power a pivot-style bar chart in the dashboard\r\n",
        "-- Heatmap\r\n",
        "select shift, date,alert_count,avg_heart_rate from cat_healthcare_iot_patients.gold.gold_shift_summary"
      ]
    },
    {
      "name": "cd972e42",
      "displayName": "gold_shift_summary",
      "queryLines": [
        "SELECT \r\n",
        "  date, \r\n",
        "  shift, \r\n",
        "  total_patients, \r\n",
        "  total_readings,\r\n",
        "  alert_count\r\n",
        "FROM cat_healthcare_iot_patients.gold.gold_shift_summary\r\n",
        "ORDER BY date DESC, \r\n",
        "  CASE WHEN shift = 'morning' THEN 1 \r\n",
        "       WHEN shift = 'evening' THEN 2 \r\n",
        "       ELSE 3 END;"
      ],
      "catalog": "cat_healthcare_iot_patients",
      "schema": "gold"
    },
    {
      "name": "42d680af",
      "displayName": "gold_anomaly_alerts",
      "queryLines": [
        "SELECT \r\n",
        "  shift,\r\n",
        "  SUM(alert_count) as total_alerts,\r\n",
        "  SUM(total_readings) as total_vitals_captured,\r\n",
        "  ROUND((SUM(alert_count) / SUM(total_readings)) * 100, 2) as alert_percentage\r\n",
        "FROM cat_healthcare_iot_patients.gold.gold_shift_summary\r\n",
        "GROUP BY shift;"
      ],
      "catalog": "cat_healthcare_iot_patients",
      "schema": "gold"
    }
  ],
